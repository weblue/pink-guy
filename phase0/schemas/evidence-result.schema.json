{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boss-man.invalid/schemas/phase0/evidence-result.schema.json",
  "title": "Boss Man Phase 0 evidence result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "test_id",
    "candidate",
    "evidence_kind",
    "status",
    "source_versions",
    "host",
    "started_at",
    "ended_at",
    "fixture_commit",
    "assertions",
    "artifacts",
    "redactions",
    "mappings",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "test_id": {
      "type": "string",
      "pattern": "^P0-[A-Z0-9-]+$"
    },
    "candidate": {
      "enum": ["neutral", "direct_pi", "aoe"]
    },
    "evidence_kind": {
      "enum": ["runtime", "inspection", "measurement", "manual"]
    },
    "status": {
      "enum": ["pass", "fail", "blocked", "not_run"]
    },
    "source_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "container_runtime": { "type": ["string", "null"] }
      }
    },
    "sanitized_command": {
      "type": ["string", "null"]
    },
    "exit_code": {
      "type": ["integer", "null"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "fixture_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40,64}$"
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "passed", "observed"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "observed": {}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "media_type", "tracked"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "media_type": { "type": "string", "minLength": 1 },
          "tracked": { "type": "boolean" }
        }
      }
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["class", "count"],
        "properties": {
          "class": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "mappings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product_requirements", "technical_risks", "hard_gates"],
      "properties": {
        "product_requirements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "technical_risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "hard_gates": {
          "type": "array",
          "items": { "type": "string", "pattern": "^G-[0-9]{2}$" },
          "uniqueItems": true
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
